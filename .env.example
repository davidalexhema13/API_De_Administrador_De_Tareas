# ------------------------------------------------------------
# CONFIGURACIÓN DEL SERVIDOR
# ------------------------------------------------------------
PORT=3000

# ------------------------------------------------------------
# SEGURIDAD (JWT)
# ------------------------------------------------------------
JWT_SECRET=escribe_aqui_una_clave_aleatoria_y_larga

# ------------------------------------------------------------
# BASE DE DATOS (DATABASE_URL)
# ------------------------------------------------------------

# OPCIÓN 1: PostgreSQL (Neon.tech o Local)
# Formato: postgresql://usuario:password@host:puerto/nombre_db?sslmode=require
# DATABASE_URL="postgresql://johndoe:mypassword@localhost:5432/mydb"

# OPCIÓN 2: MongoDB (Atlas o Local)
# Formato: mongodb+srv://usuario:password@cluster.mongodb.net/nombre_db
# DATABASE_URL="mongodb+srv://admin:12345@cluster0.mongodb.net/gestion_tareas"

# PEGA AQUÍ TU CONEXIÓN REAL:
DATABASE_URL=tu_url_de_conexion_aqui