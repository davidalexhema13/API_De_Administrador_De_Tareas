generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Modelo de usuario del sistema
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String   /// Contraseña hasheada con bcrypt
  tasks     Task[]
  createdAt DateTime @default(now())
}

/// Modelo de tarea asociada a un usuario
model Task {
  id                Int       @id @default(autoincrement())
  title             String
  description       String?
  status            String    @default("pendiente") /// pendiente | en curso | completada
  fecha_vencimiento DateTime?
  userId            Int
  user              User      @relation(fields: [userId], references: [id])
  createdAt         DateTime  @default(now())
}